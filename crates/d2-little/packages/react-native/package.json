{
  "name": "@kookyleo/supramark-d2-native-rn",
  "version": "0.1.0",
  "description": "React Native native FFI wrapper for d2-little — D2 diagrams to SVG via the supramark-d2-native Rust staticlib on iOS / Android.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "react-native": "src/index.ts",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kookyleo/supramark.git",
    "directory": "crates/d2-little/packages/react-native"
  },
  "author": "kookyleo <kookyleo@gmail.com>",
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "scripts",
    "!**/__tests__",
    "!**/.gitkeep"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typescript": "tsc --noEmit",
    "build": "bob build || echo 'react-native-builder-bob not installed — skipping prepack'",
    "prepack": "bob build || true",
    "prepare-native": "node scripts/prepare-native.js"
  },
  "keywords": [
    "react-native",
    "d2",
    "diagram",
    "svg",
    "supramark"
  ],
  "peerDependencies": {
    "@supramark/engines": "workspace:*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {},
  "codegenConfig": {
    "name": "SupramarkD2NativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.supramark.d2native"
    }
  }
}
