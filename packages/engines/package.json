{
  "name": "@supramark/engines",
  "version": "0.1.0",
  "description": "supramark 的本地图表/公式渲染引擎：纯函数 engine + config 驱动 runtime。",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    },
    "./runtime/createRender": {
      "types": "./src/runtime/createRender.ts",
      "default": "./src/runtime/createRender.ts"
    },
    "./mermaid": {
      "types": "./src/mermaid/index.ts",
      "default": "./src/mermaid/index.ts"
    },
    "./mathjax": {
      "types": "./src/mathjax/index.ts",
      "default": "./src/mathjax/index.ts"
    },
    "./graphviz": {
      "types": "./src/graphviz/index.ts",
      "default": "./src/graphviz/index.ts"
    },
    "./graphviz/web-adapter": {
      "types": "./src/graphviz/web-adapter.ts",
      "default": "./src/graphviz/web-adapter.ts"
    },
    "./graphviz/rn-adapter": {
      "types": "./src/graphviz/rn-adapter.ts",
      "default": "./src/graphviz/rn-adapter.ts"
    },
    "./echarts": {
      "types": "./src/echarts/index.ts",
      "default": "./src/echarts/index.ts"
    },
    "./vega-lite": {
      "types": "./src/vega-lite/index.ts",
      "default": "./src/vega-lite/index.ts"
    },
    "./web": {
      "types": "./src/web.ts",
      "default": "./src/web.ts"
    },
    "./rn": {
      "types": "./src/rn.ts",
      "default": "./src/rn.ts"
    },
    "./host-bridge": {
      "types": "./src/host-bridge.ts",
      "default": "./src/host-bridge.ts"
    },
    "./code-highlight": {
      "types": "./src/code-highlight.ts",
      "default": "./src/code-highlight.ts"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@kookyleo/graphviz-anywhere-web": "workspace:*",
    "@kookyleo/graphviz-anywhere-rn": "workspace:*",
    "mathjax-full": "^3.2.2"
  },
  "peerDependencies": {
    "echarts": "^5",
    "vega": "^5",
    "vega-lite": "^5",
    "@kookyleo/plantuml-little-web": "workspace:*",
    "@kookyleo/d2-little-web": "workspace:*",
    "@kookyleo/mermaid-little-web": "workspace:*"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "vega": {
      "optional": true
    },
    "vega-lite": {
      "optional": true
    },
    "@kookyleo/plantuml-little-web": {
      "optional": true
    },
    "@kookyleo/d2-little-web": {
      "optional": true
    },
    "@kookyleo/mermaid-little-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
