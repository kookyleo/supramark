{
  "name": "@supramark/core",
  "version": "0.1.0",
  "description": "supramark 核心：AST 类型定义、Markdown 解析与插件系统。",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.rn.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.rn.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./rn": {
      "types": "./src/index.rn.ts",
      "default": "./src/index.rn.ts"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "bun run --cwd ../../crates/supramark-markdown/packages/web build && bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun run --cwd ../../crates/supramark-markdown/packages/web build && bun test --coverage",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@supramark/markdown-web": "workspace:*",
    "katex": "^0.16.9"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.5.0"
  }
}
