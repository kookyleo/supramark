{
  "name": "@supramark/diagram-engine",
  "version": "0.1.0",
  "description": "supramark 的本地图表/公式渲染引擎，提供 Mermaid、MathJax 与 Graphviz SVG 渲染。",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./web": {
      "types": "./src/web.ts",
      "default": "./src/web.ts"
    },
    "./rn": {
      "types": "./src/rn.ts",
      "default": "./src/rn.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "graphviz-anywhere-react-native": "file:/tmp/graphviz-anywhere/react-native",
    "graphviz-anywhere-web": "file:/tmp/graphviz-anywhere/web",
    "mathjax-full": "^3.2.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
