{
  "name": "@supramark/web",
  "version": "0.1.0",
  "description": "supramark 的 Web 渲染层：提供 <Supramark /> React 组件等工具，用于在 React Web 应用中渲染 Markdown。",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./createSupramark": {
      "types": "./src/createSupramark.tsx",
      "default": "./src/createSupramark.tsx"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@supramark/core": "workspace:*",
    "@supramark/engines": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "^5.5.0"
  }
}
