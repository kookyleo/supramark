{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "react-jsx",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@supramark/core": ["packages/core/src/index.ts"],
      "@supramark/cli": ["packages/cli/src/index.ts"],

      "@supramark/engines": ["packages/engines/src/index.ts"],
      "@supramark/engines/types": ["packages/engines/src/types.ts"],
      "@supramark/engines/runtime": ["packages/engines/src/runtime/index.ts"],
      "@supramark/engines/runtime/createRender": ["packages/engines/src/runtime/createRender.ts"],
      "@supramark/engines/mermaid": ["packages/engines/src/mermaid/index.ts"],
      "@supramark/engines/mathjax": ["packages/engines/src/mathjax/index.ts"],
      "@supramark/engines/graphviz": ["packages/engines/src/graphviz/index.ts"],
      "@supramark/engines/graphviz/web-adapter": ["packages/engines/src/graphviz/web-adapter.ts"],
      "@supramark/engines/graphviz/rn-adapter": ["packages/engines/src/graphviz/rn-adapter.ts"],
      "@supramark/engines/echarts": ["packages/engines/src/echarts/index.ts"],
      "@supramark/engines/vega-lite": ["packages/engines/src/vega-lite/index.ts"],
      "@supramark/engines/web": ["packages/engines/src/web.ts"],
      "@supramark/engines/rn": ["packages/engines/src/rn.ts"],

      "@supramark/web": ["packages/renderers/web/src/index.ts"],
      "@supramark/web/createSupramark": ["packages/renderers/web/src/createSupramark.tsx"],
      "@supramark/rn": ["packages/renderers/rn/src/index.ts"],

      "@supramark/feature-core-markdown": ["packages/features/core-markdown/src/index.ts"],
      "@supramark/feature-gfm": ["packages/features/main/gfm/src/index.ts"],
      "@supramark/feature-math": ["packages/features/main/math/src/index.ts"],
      "@supramark/feature-footnote": ["packages/features/main/footnote/src/index.ts"],
      "@supramark/feature-emoji": ["packages/features/main/emoji/src/index.ts"],
      "@supramark/feature-definition-list": ["packages/features/main/definition-list/src/index.ts"],
      "@supramark/feature-admonition": ["packages/features/containers/admonition/src/index.ts"],
      "@supramark/feature-weather": ["packages/features/containers/weather/src/index.ts"],
      "@supramark/feature-html-page": ["packages/features/containers/html-page/src/index.ts"],
      "@supramark/feature-map": ["packages/features/containers/map/src/index.ts"],
      "@supramark/feature-mermaid": ["packages/features/diagrams/mermaid/src/index.ts"],
      "@supramark/feature-diagram-dot": ["packages/features/diagrams/dot/src/index.ts"],
      "@supramark/feature-diagram-echarts": ["packages/features/diagrams/echarts/src/index.ts"],
      "@supramark/feature-diagram-vega-lite": ["packages/features/diagrams/vega-lite/src/index.ts"]
    }
  }
}
