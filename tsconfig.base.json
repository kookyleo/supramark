{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "react-jsx",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "react": ["node_modules/.bun/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["node_modules/.bun/node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["node_modules/.bun/node_modules/@types/react-dom/index.d.ts"],
      "@supramark/core": ["packages/core/src/index.ts"],
      "@supramark/feature-*": ["packages/features/feature-*/src/index.ts"],
      "@supramark/web": ["packages/renderers/web/src/index.ts"],
      "@supramark/rn": ["packages/renderers/rn/src/index.ts"]
    }
  }
}
