{
  "name": "supramark",
  "version": "0.1.0",
  "private": true,
  "description": "可扩展的 Markdown + 图表渲染集成库，面向 React Native / 小程序平台宿主。",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/core",
    "packages/renderers/*",
    "packages/features/*",
    "packages/features/*/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "test": "bun run --workspaces --if-present test",
    "test:core": "bun run --filter @supramark/core test",
    "test:features": "bun run --filter '@supramark/feature-*' test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx && bun run features:lint",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "features:lint": "bun scripts/features-lint.ts",
    "feature:lint": "bun scripts/feature-lint.ts --strict",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "feature:create": "bun scripts/feature-create.ts",
    "feature:update": "bun scripts/feature-update.ts",
    "feature:del": "bun scripts/feature-del.ts",
    "features:sync": "bun scripts/features-sync.ts && bun scripts/features-gen-bundle.ts && bun run docs:generate",
    "docs:generate": "bun scripts/doc-gen-features.ts && bun scripts/doc-gen-api.ts && bun scripts/doc-gen-example.ts",
    "quality": "bun scripts/project-quality.ts",
    "feature:preview:web": "bun scripts/feature-preview-web.ts",
    "feature:preview:android": "bun --cwd examples/react-native android",
    "feature:preview:ios": "bun --cwd examples/react-native ios",
    "feature:preview:macos": "bun --cwd examples/react-native macos",
    "feature:preview:windows": "bun --cwd examples/react-native windows"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "expo": "~54.0.29",
    "output": "workspace:*",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "pnpm": {
    "overrides": {
      "@kookyleo/d2-lib-web": "file:/Users/leo/XData/Starbucks/kookyleo/d2-little/packages/web"
    }
  }
}
