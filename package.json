{
  "name": "supramark",
  "version": "0.1.0",
  "private": true,
  "description": "可扩展的 Markdown + 图表渲染集成库，面向 React Native / 小程序平台宿主。",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/engines",
    "packages/renderers/*",
    "packages/features/core-markdown",
    "packages/features/main/*",
    "packages/features/containers/*",
    "packages/features/diagrams/*",
    "packages/features/cards/*",
    "examples/react-native",
    "examples/react-web-csr",
    "crates/*/packages/web",
    "crates/*/packages/react-native",
    "crates/vison/vison-renderers/web",
    "crates/vison/vison-renderers/rn"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run build:wasm markdown && bun run --workspaces --if-present test",
    "test:core": "bun run --filter @supramark/core test",
    "test:features": "bun run --filter '@supramark/feature-*' test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0 && bun run features:lint",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:types": "bun scripts/lint-types.ts",
    "features:lint": "bun scripts/features-lint.ts",
    "feature:lint": "bun scripts/feature-lint.ts --strict",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "feature:create": "bun scripts/feature-create.ts",
    "feature:update": "bun scripts/feature-update.ts",
    "feature:del": "bun scripts/feature-del.ts",
    "features:sync": "bun scripts/features-sync.ts && bun scripts/features-gen-bundle.ts && bun run docs:generate",
    "code-highlight:manifest": "bun scripts/code-highlight-manifest.ts",
    "docs:generate": "bun scripts/doc-gen-features.ts && bun scripts/doc-gen-api.ts && bun scripts/doc-gen-example.ts",
    "quality": "bun run license:check && bun scripts/project-quality.ts",
    "license:check": "bun scripts/license-check.ts",
    "build:wasm": "bun scripts/build-wasm.ts",
    "build:profile": "bun scripts/build-profile.ts",
    "feature:preview:web": "bun scripts/feature-preview-web.ts",
    "docs:dev": "vitepress dev docs",
    "docs:preview:build": "bun run build:wasm && bun run --cwd examples/react-web-csr build -- --base /supramark/preview/ --outDir ../../docs/public/preview --emptyOutDir",
    "docs:build": "bun run docs:preview:build && bun run docs:typedoc && vitepress build docs",
    "docs:typedoc": "cd packages/core && bun run docs && cd ../.. && rm -rf docs/public/typedoc && mkdir -p docs/public && cp -r packages/core/docs/api docs/public/typedoc"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5",
    "expo": "~54.0.29"
  }
}
